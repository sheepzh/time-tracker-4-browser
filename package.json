{
    "name": "timer",
    "version": "4.1.4",
    "description": "Time tracker for browser",
    "homepage": "https://www.wfhg.cc",
    "scripts": {
        "pure-install": "npm install --include=optional --ignore-scripts",
        "dev": "rspack --config=rspack/rspack.dev.ts --watch",
        "dev:firefox": "rspack --config=rspack/rspack.dev.firefox.ts --watch",
        "dev:safari": "rspack --config=rspack/rspack.dev.safari.ts --watch",
        "dev:e2e": "rspack --config=rspack/rspack.e2e.ts",
        "analyze": "rspack --config=rspack/rspack.analyze.ts",
        "build": "rspack --config=rspack/rspack.prod.ts",
        "build:firefox": "rspack --config=rspack/rspack.prod.firefox.ts",
        "build:safari": "rspack --config=rspack/rspack.prod.safari.ts",
        "test": "rstest test/",
        "test-c": "rstest --coverage --reporter=junit test/",
        "test-e2e": "rstest test-e2e/ --pool.maxWorkers 1",
        "prepare": "husky"
    },
    "author": {
        "name": "zhy",
        "email": "returnzhy1996@outlook.com",
        "url": "https://www.github.com/sheepzh"
    },
    "repository": {
        "url": "https://github.com/sheepzh/time-tracker-4-browser"
    },
    "license": "MIT",
    "devDependencies": {
        "@crowdin/crowdin-api-client": "^1.55.0",
        "@emotion/babel-plugin": "^11.13.5",
        "@emotion/css": "^11.13.5",
        "@rsdoctor/rspack-plugin": "^1.5.5",
        "@rspack/cli": "^1.7.10",
        "@rspack/core": "^1.7.10",
        "@rstest/core": "^0.9.5",
        "@rstest/coverage-istanbul": "^0.3.0",
        "@types/chrome": "0.1.38",
        "@types/decompress": "^4.2.7",
        "@types/firefox-webext-browser": "^143.0.0",
        "@types/node": "^25.5.0",
        "@types/punycode": "^2.1.4",
        "@vue/babel-plugin-jsx": "^2.0.1",
        "babel-loader": "^10.1.1",
        "commitlint": "^20.5.0",
        "css-loader": "^7.1.4",
        "decompress": "^4.2.1",
        "fake-indexeddb": "^6.2.5",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "jszip": "^3.10.1",
        "postcss": "^8.5.8",
        "postcss-loader": "^8.2.1",
        "postcss-rtlcss": "^6.0.0",
        "puppeteer": "^24.40.0",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "6.0.2"
    },
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.2",
        "echarts": "^6.0.0",
        "element-plus": "2.13.6",
        "hash.js": "^1.1.7",
        "punycode": "^2.3.1",
        "typescript-guard": "^0.2.2",
        "vue": "^3.5.31",
        "vue-router": "^5.0.4"
    },
    "engines": {
        "node": ">=22"
    }
}